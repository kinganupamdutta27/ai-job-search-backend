# ============================================
# AI Job Search Automation - Environment Config
# ============================================

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# --- LangSmith (Tracing & Observability) ---
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=JOBSEARCH

# --- Search APIs (both used in parallel for better coverage) ---
SERP_API_KEY=your-serpapi-key-here
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# --- SMTP (Gmail with App Password for 2FA) ---
# Steps for Gmail App Password:
#   1. Go to https://myaccount.google.com/apppasswords
#   2. Select "Mail" and your device
#   3. Generate and copy the 16-character password
#   4. Paste it as SMTP_PASSWORD below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password

# --- Storage ---
UPLOAD_DIR=./uploads
